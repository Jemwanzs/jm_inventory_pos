  "query": "\n            SELECT sb.quantity_available, sb.average_cost, p.name AS product_name\n            FROM stock_balances sb\n            JOIN products p ON p.id = sb.product_id\n            WHERE sb.workspace_id = $1 AND sb.product_id = $2\n            FOR UPDATE\n            ",
