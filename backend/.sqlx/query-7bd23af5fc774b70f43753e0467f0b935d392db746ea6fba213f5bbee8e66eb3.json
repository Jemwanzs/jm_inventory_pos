  "query": "\n        UPDATE workspaces\n        SET\n            name = COALESCE($3, name),\n            type = COALESCE($4, type),\n            is_active = COALESCE($5, is_active),\n            updated_at = now()\n        WHERE id = $1 AND tenant_id = $2\n        RETURNING id, name, type as \"type\", is_active\n        ",
