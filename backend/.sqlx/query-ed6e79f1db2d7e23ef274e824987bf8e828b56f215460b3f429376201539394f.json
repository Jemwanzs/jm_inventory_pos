  "query": "\n            SELECT aws.step_order, aws.approver_user_id, u.full_name AS approver_name\n            FROM approval_workflow_steps aws\n            JOIN users u ON u.id = aws.approver_user_id\n            WHERE aws.workflow_id = $1\n            ORDER BY aws.step_order\n            ",
