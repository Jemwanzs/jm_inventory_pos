{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.action, a.module, u.email as user_email, a.created_at\n        FROM audit_logs a\n        LEFT JOIN users u ON u.id = a.user_id\n        WHERE a.tenant_id = $1 OR a.tenant_id IS NULL\n        ORDER BY a.created_at DESC\n        LIMIT 200\n        ",
