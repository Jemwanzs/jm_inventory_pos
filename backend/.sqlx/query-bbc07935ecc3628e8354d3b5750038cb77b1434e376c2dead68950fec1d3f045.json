{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.id, t.title, t.description, t.status, t.priority,\n            u.email AS \"assigned_to_email?\",\n            t.due_date, t.created_at\n        FROM tasks t\n        LEFT JOIN users u ON u.id = t.assigned_to\n        WHERE t.tenant_id = $1\n        ORDER BY t.created_at DESC\n        ",
