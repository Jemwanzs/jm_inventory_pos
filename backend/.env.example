DATABASE_URL=postgres://postgres:postgres@localhost:5432/inventory_pos
JWT_SECRET=change-me-to-a-long-random-value
PORT=8080
RUST_LOG=inventory_pos_api=debug,tower_http=debug

# Bootstrapped once on first startup if no super admin exists yet.
# The temporary password is generated at runtime and printed to the
# server log once — it is never hardcoded or stored in source control.
SUPER_ADMIN_EMAIL=admin@example.com

# Get an API key at https://resend.com. Leave unset to run without email
# (invite/verification/reset sends will be logged instead of sent).
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, or their sandbox address
# onboarding@resend.dev for testing before you verify your own domain.
EMAIL_FROM=onboarding@resend.dev

# Where the mobile/web app is served — invite emails link to
# {APP_BASE_URL}/?token=... (the app is a single-page app; AuthGate reads
# the token query param client-side). Expo web dev server by default.
APP_BASE_URL=http://localhost:19010
